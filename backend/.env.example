# ============================================================
# BACKEND SERVICE - Environment Configuration
# ============================================================

# FastAPI Server
API_HOST=0.0.0.0
API_PORT=8000

# CORS Origins (comma-separated, no spaces)
CORS_ORIGINS=http://localhost:5173,https://*.telegram-web-app-init.com

# Database (PostgreSQL)
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/crm_db

# Alternative DB params
DB_HOST=localhost
DB_PORT=5432
DB_NAME=crm_db
DB_USER=postgres
DB_PASSWORD=password

# Redis
REDIS_URL=redis://localhost:6379/0

# Security
SECRET_KEY=your-secret-key-change-this-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Telegram Bot (for backend validation)
BOT_TOKEN=your_bot_token_here

# Logging
LOG_LEVEL=INFO
DEBUG=false

# Feature Flags
ENABLE_REGISTRATION=true
ENABLE_SWAGGER=true
