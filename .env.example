# ============================================================
# For.Ever Cosmetics CRM - Environment Configuration Template
# ============================================================
# Copy this file to .env and fill in your actual values
# DO NOT commit .env to version control (it's in .gitignore)
# ============================================================

# ============================================================
# SECTION 1: BOT CONFIGURATION (Required)
# ============================================================

# Telegram Bot Token from @BotFather
# Get it at: https://t.me/BotFather
BOT_TOKEN=your_bot_token_here

# Bot Mode: polling or webhook
# Use 'polling' for development, 'webhook' for production
BOT_MODE=polling

# Webhook URL (required if BOT_MODE=webhook)
# WEBHOOK_URL=https://yourdomain.com/webhook

# Webhook Secret Token (optional, for additional security)
# WEBHOOK_SECRET=your_secret_token_here

# ============================================================
# SECTION 2: MINI APP URL (Required for production)
# ============================================================

# Mini App URL - set to your Netlify deployment URL
# This is the URL that opens when user clicks Web App button
# Example: https://forever-crm-miniapp.netlify.app
MINIAPP_URL=http://localhost:5173

# ============================================================
# SECTION 3: ADMINISTRATION (Optional)
# ============================================================

# Comma-separated list of admin Telegram user IDs
# Get your ID from @userinfobot
ADMIN_IDS=123456789,987654321

# Super Admin ID (has full system access)
SUPER_ADMIN_ID=123456789

# ============================================================
# SECTION 4: DATABASE (Stage 2)
# ============================================================

# PostgreSQL Connection URL
# Format: postgresql+asyncpg://user:password@host:port/database
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/crm_db

# Alternative: Connection parameters separately
DB_HOST=localhost
DB_PORT=5432
DB_NAME=crm_db
DB_USER=postgres
DB_PASSWORD=your_password_here

# Database connection pool settings
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30

# ============================================================
# SECTION 5: REDIS / CACHE (Stage 2-3)
# ============================================================

# Redis connection URL
REDIS_URL=redis://localhost:6379/0

# Redis cache TTL (in seconds)
REDIS_CACHE_TTL=3600

# ============================================================
# SECTION 6: WEB API (Stage 3)
# ============================================================

# FastAPI server configuration
API_HOST=0.0.0.0
API_PORT=8000

# API documentation enabled?
API_DOCS=true

# API authentication secret
# API_SECRET_KEY=your-secret-key-here

# ============================================================
# SECTION 7: SECURITY & FEATURE FLAGS
# ============================================================

# Debug mode (true/false) - NEVER use true in production!
DEBUG=false

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Rate limiting: max messages per minute per user
RATE_LIMIT_PER_MINUTE=30

# ============================================================
# SECTION 8: BUSINESS CONFIGURATION
# ============================================================

# Company info (used in messages)
COMPANY_NAME=For.Ever Cosmetics
COMPANY_PHONE=+998 XX XXX XX XX
COMPANY_EMAIL=info@forevercosmetics.uz

# Currency
DEFAULT_CURRENCY=UZS

# Timezone
TIMEZONE=Asia/Tashkent

# ============================================================
# NOTES:
# - Lines starting with # are comments
# - No quotes needed around values
# - Boolean: true/false (lowercase)
# - Lists: comma-separated, no spaces around commas
# ============================================================
